{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nimino.dev/schema/nimino-pack.schema.json",
  "title": "Nimino pack configuration",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "url": { "type": "string" },
    "name": { "type": "string" },
    "identifier": { "type": "string" },
    "id": { "type": "string" },
    "title": { "type": "string" },
    "icon": { "type": "string" },
    "profile": { "type": "string" },
    "width": { "type": "integer", "minimum": 1 },
    "height": { "type": "integer", "minimum": 1 },
    "minWidth": { "type": "integer", "minimum": 0 },
    "min_width": { "type": "integer", "minimum": 0 },
    "minHeight": { "type": "integer", "minimum": 0 },
    "min_height": { "type": "integer", "minimum": 0 },
    "zoom": { "type": "number", "minimum": 25, "maximum": 500 },
    "resizable": { "$ref": "#/$defs/boolean" },
    "useLocalFile": { "$ref": "#/$defs/boolean" },
    "use_local_file": { "$ref": "#/$defs/boolean" },
    "fullscreen": { "$ref": "#/$defs/boolean" },
    "hideTitleBar": { "$ref": "#/$defs/boolean" },
    "hide_title_bar": { "$ref": "#/$defs/boolean" },
    "hideWindowDecorations": { "$ref": "#/$defs/boolean" },
    "hide_window_decorations": { "$ref": "#/$defs/boolean" },
    "multiArch": { "$ref": "#/$defs/boolean" },
    "multi_arch": { "$ref": "#/$defs/boolean" },
    "debug": { "$ref": "#/$defs/boolean" },
    "alwaysOnTop": { "$ref": "#/$defs/boolean" },
    "always_on_top": { "$ref": "#/$defs/boolean" },
    "maximize": { "$ref": "#/$defs/boolean" },
    "maximized": { "$ref": "#/$defs/boolean" },
    "darkMode": { "$ref": "#/$defs/boolean" },
    "dark_mode": { "$ref": "#/$defs/boolean" },
    "disabledWebShortcuts": { "$ref": "#/$defs/boolean" },
    "disabled_web_shortcuts": { "$ref": "#/$defs/boolean" },
    "showSystemTray": { "$ref": "#/$defs/boolean" },
    "show_system_tray": { "$ref": "#/$defs/boolean" },
    "hideOnClose": { "$ref": "#/$defs/boolean" },
    "hide_on_close": { "$ref": "#/$defs/boolean" },
    "incognito": { "$ref": "#/$defs/boolean" },
    "wasm": { "$ref": "#/$defs/boolean" },
    "enableDragDrop": { "$ref": "#/$defs/boolean" },
    "enable_drag_drop": { "$ref": "#/$defs/boolean" },
    "keepBinary": { "$ref": "#/$defs/boolean" },
    "keep_binary": { "$ref": "#/$defs/boolean" },
    "bundle": { "$ref": "#/$defs/boolean" },
    "multiInstance": { "$ref": "#/$defs/boolean" },
    "multi_instance": { "$ref": "#/$defs/boolean" },
    "multiWindow": { "$ref": "#/$defs/boolean" },
    "multi_window": { "$ref": "#/$defs/boolean" },
    "startToTray": { "$ref": "#/$defs/boolean" },
    "start_to_tray": { "$ref": "#/$defs/boolean" },
    "forceInternalNavigation": { "$ref": "#/$defs/boolean" },
    "force_internal_navigation": { "$ref": "#/$defs/boolean" },
    "enableFind": { "$ref": "#/$defs/boolean" },
    "enable_find": { "$ref": "#/$defs/boolean" },
    "ignoreCertificateErrors": { "$ref": "#/$defs/boolean" },
    "ignore_certificate_errors": { "$ref": "#/$defs/boolean" },
    "iterativeBuild": { "$ref": "#/$defs/boolean" },
    "iterative_build": { "$ref": "#/$defs/boolean" },
    "newWindow": { "$ref": "#/$defs/boolean" },
    "new_window": { "$ref": "#/$defs/boolean" },
    "install": { "$ref": "#/$defs/boolean" },
    "inject": { "$ref": "#/$defs/stringArray" },
    "css": { "$ref": "#/$defs/stringArray" },
    "javascript": { "$ref": "#/$defs/stringArray" },
    "categories": { "$ref": "#/$defs/stringArray" },
    "permissions": { "$ref": "#/$defs/stringArray" },
    "deepLink": { "$ref": "#/$defs/stringArray" },
    "deep_link": { "$ref": "#/$defs/stringArray" },
    "proxyUrl": { "type": "string" },
    "proxy_url": { "type": "string" },
    "userAgent": { "type": "string" },
    "user_agent": { "type": "string" },
    "targets": { "type": "string" },
    "appVersion": { "type": "string" },
    "app_version": { "type": "string" },
    "activationShortcut": { "type": "string" },
    "activation_shortcut": { "type": "string" },
    "systemTrayIcon": { "type": "string" },
    "system_tray_icon": { "type": "string" },
    "internalUrlRegex": { "type": "string" },
    "internal_url_regex": { "type": "string" },
    "safeDomain": { "type": "string" },
    "safe_domain": { "type": "string" },
    "installerLanguage": { "type": "string" },
    "installer_language": { "type": "string" },
    "description": { "type": "string" },
    "publisher": { "type": "string" },
    "homepage": { "type": "string" }
  },
  "$defs": {
    "boolean": { "type": "boolean" },
    "stringArray": { "type": "array", "items": { "type": "string", "minLength": 1 } }
  }
}
